# Copy to `.env` (or export in your shell) to run MindBridge with LIVE
# DigitalOcean serverless inference. Without these, MindBridge still runs fully
# in self-contained demo mode — no key required.

# Your DigitalOcean model access key (console -> API -> Model access keys).
MINDBRIDGE_INFERENCE_KEY=

# Any model id available in your DigitalOcean model playground.
MINDBRIDGE_MODEL=llama3.3-70b-instruct

# Optional overrides:
# MINDBRIDGE_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
# PORT=8080
